{% block sw_product_layout_assignment_button_edit %}
    <sw-button
        class="sw-product-layout-assignment__button"
        size="small"
        :disabled="!acl.can('product.editor') || undefined"
        v-if="!isNeosPage"
        @click="openInPageBuilder"
    >
        {{ cmsPage ? $tc('sw-product.layoutAssignment.textEditInDesigner') : $tc('sw-product.layoutAssignment.textCreateNewLayout') }}
    </sw-button>
    <sw-button
        class="sw-product-layout-assignment__button"
        size="small"
        :disabled="!acl.can('product.editor') || undefined"
        v-if="isNeosPage"
        @click="openInNeos"
    >
        {{ $tc('sw-category.base.cms.editInNeos') }}
    </sw-button>

    {# FIXME remove doubled class and add styling for the preview button class #}
    <sw-button
        class="sw-product-preview__button sw-product-layout-assignment__button"
        size="small"
        :disabled="!acl.can('product.editor') || undefined"
        @click="openPreviewModal"
        >
        {{ $tc('sw-category.base.cms.preview.buttonText') }}
    </sw-button>
{% endblock %}
{% block sw_product_layout_assignment_button_delete %}
    {% parent %}
    <sw-button
        variant="primary"
        size="small"
        :disabled="!acl.can('category.editor')"
        :isLoading="isCreatingInNeos"
        @click="createInNeos"
        v-if="!isNeosPage"
    >
        {{ $tc('sw-product.base.cms.createInNeos.buttonText') }}
    </sw-button>
{% endblock %}
