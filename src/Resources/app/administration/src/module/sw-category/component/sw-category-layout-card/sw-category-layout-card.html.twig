{% block sw_category_detail_layout_desc_actions_layout %}
    {% parent %}
    <sw-button
        class="sw-product-preview__button sw-product-layout-assignment__button"
        size="small"
        :disabled="!acl.can('category.editor') || undefined"
        @click="openPreviewModal"
    >
        {{ $t('sw-category.base.cms.preview.buttonText') }}
    </sw-button>

    <nlx-preview-modal
        v-if="showPreviewModal"
        :headline="$t('sw-category.base.cms.preview.modal.headline')"
        :cmsPageId="cmsPage.id"
        @modal-preview-select="onSelectPreview"
        @modal-close="onClosePreviewModal"
    ></nlx-preview-modal>
{% endblock %}

{% block sw_category_detail_layout_desc_actions_designer %}
    <template v-if="renderContextUi">
        <sw-context-menu-item
            v-if="!isNeosPage"
            :disabled="!acl.can('category.editor')"
            class="sw-category-detail-layout__open-in-pagebuilder"
            @click="openInPagebuilder"
        >
            {{ cmsPage ? $t('sw-category.base.cms.editInPagebuilder') : $t('sw-category.base.cms.editInPagebuilderEmpty') }}
        </sw-context-menu-item>
        <sw-context-menu-item
            v-if="isNeosPage"
            :disabled="!acl.can('category.editor')"
            class="sw-category-detail-layout__open-in-pagebuilder"
            @click="openInNeos"
        >
            {{ $t('sw-category.base.cms.openInNeos.buttonText') }}
        </sw-context-menu-item>
    </template>
    <template v-else>
        <sw-button
            class="sw-category-detail-layout__open-in-pagebuilder"
            size="small"
            :disabled="!acl.can('category.editor')"
            v-if="!isNeosPage"
            @click="openInPagebuilder"
        >
            {{ cmsPage ? $t('sw-category.base.cms.editInPagebuilder') : $t('sw-category.base.cms.editInPagebuilderEmpty') }}
        </sw-button>
        <sw-button
            class="sw-category-detail-layout__open-in-pagebuilder"
            size="small"
            :disabled="!acl.can('category.editor')"
            v-if="isNeosPage"
            @click="openInNeos"
        >
            {{ $t('sw-category.base.cms.openInNeos.buttonText') }}
        </sw-button>
    </template>
{% endblock %}
{% block sw_category_detail_layout_desc_actions_remove %}
    {% parent %}
    <template v-if="renderContextUi">
        <sw-context-menu-item
            v-if="!isNeosPage"
            :disabled="!acl.can('category.editor')"
            class="sw-category-detail-layout__layout-reset"
            @click="createInNeos"
        >
            {{ $t('sw-category.base.cms.createInNeos.buttonText') }}
        </sw-context-menu-item>

    </template>
    <template v-else>
        <sw-button
            variant="primary"
            size="small"
            :disabled="!acl.can('category.editor')"
            :isLoading="isCreatingInNeos"
            @click="createInNeos"
            v-if="!isNeosPage"
        >
            {{ $t('sw-category.base.cms.createInNeos.buttonText') }}
        </sw-button>
    </template>
{% endblock %}
